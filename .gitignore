# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Environment
.env
*.env.local

# Language state (set by setup.sh --lang)
.claude/.current-lang

# Claude Code local settings (contains MCP server permissions, may contain API keys)
.claude/settings.local.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Virtual environment
.venv/

# Raw data (large files managed separately)
raw/papers/*.pdf

# Reconnaissance cloned repos (large, not version-controlled)
references/

# Experiment workspaces (generated code, results, venvs)
experiments/code/*/.venv/
experiments/code/*/.pid
experiments/code/*/wandb/
experiments/code/*/checkpoints/